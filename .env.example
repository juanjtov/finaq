# Copy this file to .env and fill in your keys + chosen models.
# .env is gitignored; .env.example is committed.

# --- API keys ---
OPENROUTER_API_KEY=sk-or-v1-...
TAVILY_API_KEY=tvly-...
SEC_EDGAR_USER_AGENT="FINAQ/0.1 juanjtov@toruktech.com"

# --- Model strings ---
# Defaults below are 2026-04-26 OpenRouter latest. Swap any of these and the
# whole system picks up the new model on next process restart — no code change.
MODEL_TRIAGE=anthropic/claude-haiku-4.5
MODEL_FUNDAMENTALS=anthropic/claude-sonnet-4.6
MODEL_FILINGS=anthropic/claude-sonnet-4.6
MODEL_NEWS=anthropic/claude-sonnet-4.6
MODEL_RISK=anthropic/claude-sonnet-4.6
MODEL_SYNTHESIS=anthropic/claude-opus-4.7
MODEL_ROUTER=anthropic/claude-haiku-4.5
MODEL_ADHOC_THESIS=anthropic/claude-sonnet-4.6
MODEL_JUDGE=anthropic/claude-haiku-4.5
MODEL_AGENT_QA=anthropic/claude-haiku-4.5
MODEL_EMBEDDINGS=text-embedding-3-small

# --- Phase 1 (uncomment when starting Step 9) ---
# NOTION_API_KEY=secret_...
# NOTION_DB_THESES=
# NOTION_DB_REPORTS=
# NOTION_DB_ALERTS=
# NOTION_DB_WATCHLIST=

# --- Phase 1 (uncomment when starting Step 10) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# STREAMLIT_PUBLIC_URL=http://localhost:8501

# --- Observability (Step 5z) ---
# Local SQLite telemetry at data_cache/state.db is always on (no key required).
# It records graph runs, node runs, alerts, errors — feeds the dashboard's
# Mission Control page.
#
# LangSmith auto-traces every LangGraph node + LLM call (full prompt + response
# + per-call cost) when TRACING=true. Free tier covers personal use. Optional;
# leave commented to disable.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=finaq
